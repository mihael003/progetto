<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Compito: Condizione if-else</title>

    <style>

        body {background-color: rgb(13, 87, 112);
            color: rgb(150, 60, 192);
            font-family: sans-serif;
            text-align: center;
        }

        #titolo {text-align: center;
            text-shadow: 1px 1px darkblue;
        }

        .box {margin:auto;
            border:1px 1px solid blue;
            border-radius: 30px;
            background-color: rgb(34, 84, 148);
            width: 50%;
            height:auto;
            padding:10px;
            line-height: 20px;
            color:rgb(21, 186, 145);
            text-align: center;
        }

        .button {border: none;
            background-color: rgb(0, 0, 245);
            color:rgb(231, 15, 177);
            padding: 10px;
            margin-top: 10px;
            border-radius: 40px;
        }

        .button:hover {background-color: rgb(0, 255, 255);
            color:rgb(0, 0, 255);
        }

        #risultato {font-size: larger;
                    text-align: center;
                    margin: auto;
                    width: 10%;
                    height: auto;
                    padding: 10px;
                    border-radius: 30px;

        }

        p {color: rgb(255, 0, 0);
            font-size: larger;
            text-shadow: 1px 1px black;
            background-color: rgb(34, 84, 148);
        }

    </style>
</head>

<body>

<h1 id="titolo">Compito: Condizione if-else e swich case</h1>

    <div class="box">
        <label>inserisci qui il tuo numero</label><br>

        <input type="number" id="tuonumero"> 
        <input type="submit" onclick="calcolonumero()" class="button">
    </div>

<p id="risultato"></p>

<script>
    function calcolonumero() {

        let elementoHtmlTuoNumero = document.getElementById('tuonumero');

        let valoreInput = elementoHtmlTuoNumero.value;

        let numero = Number(valoreInput);

        let elementoHtmlRisultato = document.getElementById('risultato');



        if (numero % 2 == 0) {

            elementoHtmlRisultato.innerHTML = "il numero è pari";
        }

        else {

            elementoHtmlRisultato.innerHTML = "il numero è dispari";
        }

    }

</script>

</body>
</html>
